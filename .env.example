# VibeStock Environment Configuration
# Copy this to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vibestock

# JWT signing secret (change in production!)
JWT_SECRET=vibestock_super_secret_jwt_key_mca_2024_change_me

# Server bind configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Token expiry in hours
JWT_EXPIRY_HOURS=24

# Rust log level: error | warn | info | debug | trace
RUST_LOG=api=debug,tower_http=debug
